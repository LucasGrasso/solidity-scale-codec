{
  "extends": "solhint:recommended",
  "rules": {
    "max-line-length": ["warn", 120],
    "quotes": ["error", "double"],
    "no-unused-vars": ["error"],
    "no-inline-assembly": "off",
    "no-unused-import": ["error"],
    "function-max-lines": ["warn", 80],
    "use-natspec": ["warn", {
      "author": {
          "enabled": false,
          "ignore": {}
        }
    }]
  }
}
