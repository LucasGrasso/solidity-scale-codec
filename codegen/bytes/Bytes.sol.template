	/// @param offset The starting index in `data` from which to calculate the encoded size of the `bytes{{n}}`.
	/// @return The number of bytes that the `bytes{{n}}` would occupy when SCALE-encoded.
    function encodedSizeAt(bytes memory data, uint256 offset) internal pure returns (uint256) {
