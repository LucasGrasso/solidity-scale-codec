/// @dev SCALE reference: https://docs.polkadot.com/polkadot-protocol/basics/data-encoding
library Bytes{{n}} {
    error InvalidBytes{{n}}Length();

    /// @notice Encodes an `bytes{{n}}` into SCALE format.
    /// @param value The `bytes{{n}}` to encode.
